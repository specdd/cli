Spec: Shared Constants
Purpose:
  Provide shared values for SpecDD paths, release metadata, URLs, version parsing, and common CLI text.

Structure:
  ./constants.ts: Shared constants implementation.

Owns:
  ./constants.ts

Can modify:
  ./constants.ts

Must:
  Define @SPECDD_DIRECTORY_PATH, @SPECDD_BOOTSTRAP_FILE_NAME, @SPECDD_LOCAL_BOOTSTRAP_FILE_NAME, @SPECDD_GITIGNORE_FILE_NAME, @SPECDD_BOOTSTRAP_PATH, @SPECDD_GITIGNORE_PATH, and @SPECDD_LOCAL_BOOTSTRAP_GITIGNORE_CONTENT.
  Define @SPECDD_HOMEPAGE_URL, @SPECDD_CHANGELOG_URL, @SPECDD_CLI_HELP_URL, and @SPECDD_GITHUB_RELEASE_BASE_URL.
  Define @SPECDD_DISTRIBUTION_ASSET_NAME and @SPECDD_SIGNATURE_ASSET_NAME.
  Define @AGENTSKILLS_GITHUB_RELEASE_BASE_URL, @AGENTSKILLS_RELEASE_ASSET_NAME, @AGENTSKILLS_SIGNATURE_ASSET_NAME, @AGENTSKILLS_DIRECTORY_PATH, @AGENTSKILLS_SKILLS_DIRECTORY_PATH, and @AGENTSKILLS_SKILL_PREFIX.
  Define @SPECDD_VERSION_PATTERN, @SPECDD_LEADING_V_VERSION_PATTERN, @SPECDD_VERSION_PART_SEPARATOR, and @SPECDD_FRONT_MATTER_DELIMITER.
  Define @SPECDD_COPYRIGHT_NOTICE and @CLI_HELP_FOOTER.
  Keep values static and free of runtime side effects.

Must not:
  Read environment variables.
  Perform filesystem or network operations.

Exposes:
  @SPECDD_DIRECTORY_PATH
  @SPECDD_BOOTSTRAP_FILE_NAME
  @SPECDD_LOCAL_BOOTSTRAP_FILE_NAME
  @SPECDD_GITIGNORE_FILE_NAME
  @SPECDD_BOOTSTRAP_PATH
  @SPECDD_GITIGNORE_PATH
  @SPECDD_LOCAL_BOOTSTRAP_GITIGNORE_CONTENT
  @SPECDD_HOMEPAGE_URL
  @SPECDD_CHANGELOG_URL
  @SPECDD_CLI_HELP_URL
  @SPECDD_GITHUB_RELEASE_BASE_URL
  @SPECDD_DISTRIBUTION_ASSET_NAME
  @SPECDD_SIGNATURE_ASSET_NAME
  @AGENTSKILLS_GITHUB_RELEASE_BASE_URL
  @AGENTSKILLS_RELEASE_ASSET_NAME
  @AGENTSKILLS_SIGNATURE_ASSET_NAME
  @AGENTSKILLS_DIRECTORY_PATH
  @AGENTSKILLS_SKILLS_DIRECTORY_PATH
  @AGENTSKILLS_SKILL_PREFIX
  @SPECDD_COPYRIGHT_NOTICE
  @CLI_HELP_FOOTER
  @SPECDD_VERSION_PATTERN
  @SPECDD_LEADING_V_VERSION_PATTERN
  @SPECDD_VERSION_PART_SEPARATOR
  @SPECDD_FRONT_MATTER_DELIMITER
